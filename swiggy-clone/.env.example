# ═══════════════════════════════════════
# Swiggy Clone — Environment Variables
# ═══════════════════════════════════════

# PostgreSQL
POSTGRES_PASSWORD=SuperSecure123!

# JWT
JWT_SECRET_KEY=your-256-bit-secret-key-here
JWT_ISSUER=swiggy-clone-api
JWT_AUDIENCE=swiggy-clone-client
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# Redis
REDIS_PASSWORD=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Elasticsearch
ELASTICSEARCH_URI=http://localhost:9200

# Firebase (FCM)
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Google Maps
GOOGLE_MAPS_API_KEY=

# S3 / Blob Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-south-1

# SMTP (Email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@swiggyclone.com

# Twilio / MSG91 (SMS/OTP)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
