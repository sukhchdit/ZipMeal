{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=swiggyclone;Username=postgres;Password=postgres;Include Error Detail=true",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "SecretKey": "CHANGE_ME_SuperSecretKeyThatIsAtLeast32BytesLong!!",
    "Issuer": "SwiggyClone.Api",
    "Audience": "SwiggyClone.Clients",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroupId": "swiggyclone-api",
    "NotificationConsumerGroupId": "swiggyclone-notifications"
  },
  "Elasticsearch": {
    "Uri": "http://localhost:9200"
  },
  "OpenTelemetry": {
    "JaegerEndpoint": "http://localhost:4317"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithEnvironmentName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "SwiggyClone.Api"
    }
  },
  "AllowedHosts": "*"
}
