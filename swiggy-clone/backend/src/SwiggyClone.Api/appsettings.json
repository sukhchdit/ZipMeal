{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=swiggyclone;Username=postgres;Password=postgres;Include Error Detail=true;Maximum Pool Size=200;Minimum Pool Size=5",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "SecretKey": "CHANGE_ME_SuperSecretKeyThatIsAtLeast32BytesLong!!",
    "Issuer": "SwiggyClone.Api",
    "Audience": "SwiggyClone.Clients",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroupId": "swiggyclone-api",
    "NotificationConsumerGroupId": "swiggyclone-notifications"
  },
  "Elasticsearch": {
    "Uri": "http://localhost:9200"
  },
  "OpenTelemetry": {
    "JaegerEndpoint": "http://localhost:4317"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithEnvironmentName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "SwiggyClone.Api"
    }
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1s",
        "Limit": 10
      },
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 120
      },
      {
        "Endpoint": "*:/api/v1/auth/login",
        "Period": "15m",
        "Limit": 10
      },
      {
        "Endpoint": "*:/api/v1/auth/register",
        "Period": "1h",
        "Limit": 5
      },
      {
        "Endpoint": "*:/api/v1/auth/otp/send",
        "Period": "1h",
        "Limit": 5
      },
      {
        "Endpoint": "*:/api/v1/auth/token/refresh",
        "Period": "1m",
        "Limit": 10
      }
    ]
  },
  "Security": {
    "ApiKeys": [],
    "AdminIpWhitelist": []
  },
  "Resilience": {
    "Elasticsearch": {
      "RetryCount": 3,
      "RetryBaseDelaySeconds": 1,
      "CircuitBreakerFailureThreshold": 5,
      "CircuitBreakerDurationSeconds": 30,
      "TimeoutSeconds": 10
    },
    "Kafka": {
      "RetryCount": 2,
      "RetryBaseDelaySeconds": 0.5
    },
    "RedisCart": {
      "RetryCount": 2,
      "RetryBaseDelaySeconds": 0.25,
      "CircuitBreakerFailureThreshold": 5,
      "CircuitBreakerDurationSeconds": 15,
      "TimeoutSeconds": 5
    },
    "Idempotency": {
      "DefaultExpirationMinutes": 60
    }
  },
  "Firebase": {
    "ServiceAccountPath": ""
  },
  "BackgroundJobs": {
    "ExpiredTokenCleanupCron": "0 0 2 * * ?",
    "SubscriptionExpiryCron": "0 0 * * * ?",
    "AbandonedOrderCleanupCron": "0 0/15 * * * ?",
    "StalledPaymentCron": "0 0/10 * * * ?",
    "ExpiredCouponDeactivationCron": "0 5 * * * ?",
    "DineInSessionTimeoutCron": "0 0/10 * * * ?",
    "TokenRetentionDays": 7,
    "AbandonedOrderMinutes": 60,
    "StalledPaymentMinutes": 30,
    "DineInPaymentPendingMinutes": 30
  },
  "AllowedHosts": "*"
}
