{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=swiggyclone;Username=postgres;Password=postgres;Include Error Detail=true",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "SecretKey": "CHANGE_ME_SuperSecretKeyThatIsAtLeast32BytesLong!!",
    "Issuer": "SwiggyClone.Api",
    "Audience": "SwiggyClone.Clients",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroupId": "swiggyclone-api",
    "NotificationConsumerGroupId": "swiggyclone-notifications"
  },
  "Elasticsearch": {
    "Uri": "http://localhost:9200"
  },
  "OpenTelemetry": {
    "JaegerEndpoint": "http://localhost:4317"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithEnvironmentName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "SwiggyClone.Api"
    }
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1s",
        "Limit": 10
      },
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 120
      },
      {
        "Endpoint": "*:/api/v1/auth/login",
        "Period": "15m",
        "Limit": 10
      },
      {
        "Endpoint": "*:/api/v1/auth/register",
        "Period": "1h",
        "Limit": 5
      },
      {
        "Endpoint": "*:/api/v1/auth/otp/send",
        "Period": "1h",
        "Limit": 5
      },
      {
        "Endpoint": "*:/api/v1/auth/token/refresh",
        "Period": "1m",
        "Limit": 10
      }
    ]
  },
  "Security": {
    "ApiKeys": [],
    "AdminIpWhitelist": []
  },
  "AllowedHosts": "*"
}
